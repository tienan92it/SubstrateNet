{
  "name": "@substrate-net/cli",
  "version": "0.1.0",
  "description": "Cross-project skills. One local view. Grounded skill graph and dashboard from code and AI agent conversations — local SQLite.",
  "homepage": "https://tienan92it.github.io/SubstrateNet/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tienan92it/SubstrateNet.git"
  },
  "bugs": "https://github.com/tienan92it/SubstrateNet/issues",
  "author": "An Tran",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "subnet": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets && node -e \"require('fs').chmodSync('dist/cli/index.js', 0o755)\"",
    "copy-assets": "node -e \"const fs=require('fs');fs.mkdirSync('dist/db',{recursive:true});['code-schema.sql','knowledge-schema.sql','global-schema.sql'].forEach(f=>fs.copyFileSync('src/db/'+f,'dist/db/'+f));fs.mkdirSync('dist/canvas/templates',{recursive:true});if(fs.existsSync('src/canvas/templates'))fs.readdirSync('src/canvas/templates').forEach(f=>fs.copyFileSync('src/canvas/templates/'+f,'dist/canvas/templates/'+f));if(fs.existsSync('dashboard/dist/index.html')){fs.mkdirSync('dist/dashboard/app',{recursive:true});fs.cpSync('dashboard/dist','dist/dashboard/app',{recursive:true});}\"",
    "build:dashboard": "cd dashboard && npm install && npm run build",
    "build:all": "npm run build:dashboard && npm run build",
    "dev": "tsc --watch",
    "cli": "npm run build && node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "agents:eval": "npm run build && node dist/cli/index.js agents eval",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "knowledge-graph",
    "code-intelligence",
    "mcp",
    "conversations",
    "agents",
    "local-first"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ajv": "^8.17.1",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.3",
    "commander": "^14.0.2",
    "ignore": "^7.0.5",
    "picomatch": "^4.0.3",
    "tree-sitter-wasms": "^0.1.11",
    "web-tree-sitter": "^0.25.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@cursor/sdk": "^1.0.17",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.19.30",
    "@types/picomatch": "^4.0.2",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  }
}
